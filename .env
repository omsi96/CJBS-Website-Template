# ============================================================================
#  CJBS x CODED — Workshop environment
# ============================================================================
#  This file is COMMITTED on purpose. This is a teaching template, not prod.
#  The OpenRouter key below is a workshop key meant to be ROTATED after the
#  session. Treat it as disposable. NEVER commit real secrets in a real repo.
# ============================================================================

# --- Database (SQLite, zero-config) ---
DATABASE_URL="file:./dev.db"

# --- Session signing (any random string is fine for the workshop) ---
SESSION_SECRET="cjbs-coded-workshop-demo-secret-change-me"

# --- OpenRouter (LLM access). Replace REPLACE_ME with the workshop key. ---
# Get one free at https://openrouter.ai/keys  → rotate it after the workshop.
OPENROUTER_API_KEY="sk-or-v1-REPLACE_ME"
OPENROUTER_MODEL="anthropic/claude-3.5-haiku"

# --- Supabase (OPTIONAL) ---------------------------------------------------
# You do NOT need this to run the app. The default DB is local SQLite (above).
# To use your own Supabase project instead, run:  npm run connect:supabase
# (or paste the values below). Keeping these blank = stay on SQLite. Fine!
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Optional: to make Supabase Postgres your MAIN database (instead of SQLite),
# set this to your Supabase connection string AND switch the provider in
# prisma/schema.prisma from "sqlite" to "postgresql". See docs/SUPABASE.md.
# SUPABASE_DATABASE_URL=""
